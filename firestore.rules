rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function workspaceIdForUser() {
      return signedIn() && userDoc(request.auth.uid).exists()
        ? (userDoc(request.auth.uid).data.workspaceId)
        : null;
    }

    function isWorkspaceMember(workspaceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.members;
    }

    // Users: allow users to read/write only their own doc.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Workspaces: members can read/write.
    // Owner-only actions (transfer ownership, deletion) are modeled as deletes or ownerId changes.
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow delete: if signedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
        && request.auth.uid == resource.data.ownerId;

      // Members can update settings, but only owner may change ownerId.
      allow update: if isWorkspaceMember(workspaceId) && (
        request.resource.data.ownerId == resource.data.ownerId
        || request.auth.uid == resource.data.ownerId
      );
    }

    // Sessions: primary access by workspaceId; legacy access by userId.
    match /sessions/{sessionId} {
      allow read, write: if (
        // New: workspace scoped
        (resource.data.workspaceId is string
          && isWorkspaceMember(resource.data.workspaceId)
          && workspaceIdForUser() == resource.data.workspaceId)
        ||
        // Legacy: user scoped
        (resource.data.workspaceId == null
          && resource.data.userId == request.auth.uid)
      );

      allow create: if signedIn() && (
        (request.resource.data.workspaceId is string
          && isWorkspaceMember(request.resource.data.workspaceId)
          && workspaceIdForUser() == request.resource.data.workspaceId)
        ||
        (request.resource.data.workspaceId == null
          && request.resource.data.userId == request.auth.uid)
      );
    }

    // Feedback: primary access by workspaceId; legacy access by userId.
    match /feedback/{feedbackId} {
      allow read, write: if (
        (resource.data.workspaceId is string
          && isWorkspaceMember(resource.data.workspaceId)
          && workspaceIdForUser() == resource.data.workspaceId)
        ||
        (resource.data.workspaceId == null
          && resource.data.userId == request.auth.uid)
      );

      allow create: if signedIn() && (
        (request.resource.data.workspaceId is string
          && isWorkspaceMember(request.resource.data.workspaceId)
          && workspaceIdForUser() == request.resource.data.workspaceId)
        ||
        (request.resource.data.workspaceId == null
          && request.resource.data.userId == request.auth.uid)
      );
    }

    // Comments: primary access by workspaceId (derived from session/feedback); legacy allowed via session userId not enforced here.
    match /comments/{commentId} {
      allow read, write: if (
        (resource.data.workspaceId is string
          && isWorkspaceMember(resource.data.workspaceId)
          && workspaceIdForUser() == resource.data.workspaceId)
        ||
        // Legacy: allow author to manage their own comments
        (resource.data.workspaceId == null
          && resource.data.userId == request.auth.uid)
      );

      allow create: if signedIn() && (
        (request.resource.data.workspaceId is string
          && isWorkspaceMember(request.resource.data.workspaceId)
          && workspaceIdForUser() == request.resource.data.workspaceId)
        ||
        (request.resource.data.workspaceId == null
          && request.resource.data.userId == request.auth.uid)
      );
    }

    // Keep existing session view tracking intact (non-sensitive).
    match /sessionViews/{sessionId}/views/{viewerId} {
      allow read, write: if signedIn() && request.auth.uid == viewerId;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

